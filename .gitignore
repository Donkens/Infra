# macOS junk and editor scratch files
.DS_Store
*.swp
*.swo
*.tmp

# Local backup files; quarantine or delete intentionally, never commit.
*.bak
*.bak.*
*.orig
*~
# Secrets (never commit)
*.key
*.pem
*.p12
*.pfx
*.pass
secrets/
.env
.env.*
# Local runtime logs/state; keep tracked .gitkeep placeholders only.
logs/*
!logs/.gitkeep
state/*
!state/.gitkeep

# Pi-local backups may contain sensitive service configs such as AdGuardHome.yaml.
state/backups/

# Local Codex state; machine-specific and never tracked.
.codex/

# Generated analysis and dossier files — do not commit
docs/*-dossier.md
docs/repo-analysis-*.md
