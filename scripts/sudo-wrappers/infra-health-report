#!/usr/bin/env bash
# Purpose: Agent-friendly compact Pi infra health report.
# Author:  codex-agent | Date: 2026-05-05
set -euo pipefail
IFS=$'\n\t'

readonly REPO="/home/pi/repos/infra"
readonly LOG_DIR="$REPO/logs"
readonly STATE_DIR="$REPO/state"
readonly SYSTEMCTL="/usr/bin/systemctl"
readonly JOURNALCTL="/usr/bin/journalctl"
readonly TAIL="/usr/bin/tail"
readonly DF="/usr/bin/df"
readonly TIMEOUT="/usr/bin/timeout"

status="PASS"

warn() {
  status="WARN"
  printf 'RESULT: WARN %s\n' "$1"
}

show_service() {
  local unit="$1"
  local active
  active="$("$TIMEOUT" 10s "$SYSTEMCTL" is-active "$unit" 2>/dev/null || true)"
  printf 'RESULT: service=%s active=%s\n' "$unit" "${active:-unknown}"
  if [ "$unit" = "unbound" ] || [ "$unit" = "AdGuardHome" ]; then
    if [ "$active" != "active" ]; then
      printf 'STATUS: FAIL\n'
      printf 'RESULT: FAIL %s inactive\n' "$unit"
      exit 1
    fi
  fi
}

show_timer() {
  local timer="$1"
  local active
  active="$("$TIMEOUT" 10s "$SYSTEMCTL" is-active "$timer" 2>/dev/null || true)"
  printf 'RESULT: timer=%s active=%s\n' "$timer" "${active:-unknown}"
  if [ "$active" != "active" ]; then
    warn "$timer inactive"
  fi
}

tail_if_present() {
  local label="$1"
  local file="$2"
  printf 'CHECK: %s\n' "$label"
  if [ -f "$file" ]; then
    "$TAIL" -n 3 "$file" 2>/dev/null || warn "could not read $file"
  else
    printf 'RESULT: missing\n'
  fi
}

printf 'CHECK: identity\n'
printf 'RESULT: host=%s user=%s home=%s repo=%s\n' "$(hostname -s)" "$(id -un)" "$HOME" "$REPO"
printf 'RESULT: time=%s\n' "$(date '+%F %T %Z')"

printf '\nCHECK: service active state\n'
for unit in unbound AdGuardHome dns-health.service backup-health.service infra-auto-sync.service; do
  show_service "$unit"
done

printf '\nCHECK: timer state\n'
for timer in dns-health.timer backup-health.timer infra-auto-sync.timer; do
  show_timer "$timer"
done

printf '\nCHECK: failed units\n'
"$TIMEOUT" 10s "$SYSTEMCTL" --failed --no-pager || warn "systemctl --failed returned non-zero"

printf '\n'
tail_if_present "last dns-health state" "$STATE_DIR/dns-health.last"
tail_if_present "last backup-health state" "$STATE_DIR/backup-health.last"

printf '\nCHECK: disk usage\n'
for path in "$REPO" "$STATE_DIR" "$LOG_DIR"; do
  if [ -e "$path" ]; then
    "$DF" -h "$path" 2>/dev/null | tail -n 1 | awk -v path="$path" '{print "RESULT: path=" path " size="$2" used="$3" avail="$4" pct="$5}'
  else
    warn "$path missing"
  fi
done

printf '\nCHECK: recent known-unit journals\n'
for unit in unbound AdGuardHome dns-health.service backup-health.service infra-auto-sync.service; do
  printf 'RESULT: journal unit=%s\n' "$unit"
  "$TIMEOUT" 10s "$JOURNALCTL" -u "$unit" -n 8 --no-pager 2>/dev/null || warn "journal read failed for $unit"
done

printf '\nSTATUS: %s\n' "$status"
