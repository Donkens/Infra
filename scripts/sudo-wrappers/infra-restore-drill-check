#!/usr/bin/env bash
# Purpose: Read-only restore drill readiness check for Pi DNS backups.
# Author:  codex-agent | Date: 2026-05-05
set -euo pipefail
IFS=$'\n\t'

readonly REPO="/home/pi/repos/infra"
readonly BACKUP_ROOT="$REPO/state/backups"
readonly LATEST_LINK="$BACKUP_ROOT/latest"
readonly READLINK="/usr/bin/readlink"

status="PASS"

warn() {
  status="WARN"
  printf 'RESULT: WARN %s\n' "$1"
}

check_file() {
  local label="$1"
  local path="$2"
  printf 'CHECK: %s\n' "$label"
  if [ -f "$path" ]; then
    printf 'RESULT: present path=%s\n' "$path"
  else
    warn "missing $path"
  fi
}

check_cmd() {
  local cmd="$1"
  printf 'CHECK: command %s\n' "$cmd"
  if command -v "$cmd" >/dev/null 2>&1; then
    printf 'RESULT: present path=%s\n' "$(command -v "$cmd")"
  else
    warn "$cmd missing"
  fi
}

check_file "restore guide" "$REPO/docs/restore.md"
check_file "Pi disaster restore runbook" "$REPO/runbooks/pi-sd-card-disaster-restore.md"
check_file "sudo wrapper runbook" "$REPO/runbooks/pi-sudo-wrapper-model.md"
check_file "backup script" "$REPO/scripts/backup/backup-dns-configs.sh"

printf 'CHECK: latest backup checksum readiness\n'
if [ ! -e "$LATEST_LINK" ]; then
  warn "$LATEST_LINK missing"
else
  latest_path="$("$READLINK" -f "$LATEST_LINK" 2>/dev/null || true)"
  if [ -n "$latest_path" ] && [ -d "$latest_path" ]; then
    printf 'RESULT: latest=%s\n' "$latest_path"
    if [ -f "$latest_path/meta/SHA256SUMS.txt" ]; then
      printf 'RESULT: sha256=present\n'
    else
      warn "latest backup has no SHA256SUMS"
    fi
  else
    warn "$LATEST_LINK does not resolve to a directory"
  fi
fi

printf 'CHECK: required tools\n'
for cmd in bash sha256sum tar rsync systemctl dig; do
  check_cmd "$cmd"
done

printf 'CHECK: restore execution\n'
printf 'RESULT: read-only check only; no restore performed\n'
printf 'STATUS: %s\n' "$status"
