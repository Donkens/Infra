#!/usr/bin/env bash
# Purpose: Compact DNS and infra timer status report for Pi.
# Author:  codex-agent | Date: 2026-05-05
set -euo pipefail
IFS=$'\n\t'

readonly REPO="/home/pi/repos/infra"
readonly LOG_DIR="$REPO/logs"
readonly STATE_DIR="$REPO/state"
readonly SYSTEMCTL="/usr/bin/systemctl"
readonly TAIL="/usr/bin/tail"
readonly DF="/usr/bin/df"
readonly TIMEOUT="/usr/bin/timeout"

status="PASS"

section() { printf '\nCHECK: %s\n' "$1"; }
result() { printf 'RESULT: %s\n' "$1"; }
warn() {
  status="WARN"
  printf 'RESULT: WARN %s\n' "$1"
}
fail() {
  printf 'STATUS: FAIL\n'
  printf 'RESULT: FAIL %s\n' "$1"
  exit 1
}
have_file() { [ -f "$1" ]; }

run_systemctl() {
  "$TIMEOUT" 10s "$SYSTEMCTL" "$@"
}

show_unit_state() {
  local unit="$1"
  local active enabled
  active="$(run_systemctl is-active "$unit" 2>/dev/null || true)"
  enabled="$(run_systemctl is-enabled "$unit" 2>/dev/null || true)"
  printf 'RESULT: unit=%s active=%s enabled=%s\n' "$unit" "${active:-unknown}" "${enabled:-unknown}"
  if [ "$unit" = "unbound" ] || [ "$unit" = "AdGuardHome" ]; then
    if [ "$active" != "active" ]; then
      fail "$unit is not active"
    fi
  fi
}

show_timer_active() {
  local timer="$1"
  local active
  active="$(run_systemctl is-active "$timer" 2>/dev/null || true)"
  printf 'RESULT: timer=%s active=%s\n' "$timer" "${active:-unknown}"
  if [ "$active" != "active" ]; then
    warn "$timer is not active"
  fi
}

tail_safe_log() {
  local label="$1"
  local file="$2"
  printf 'CHECK: log=%s path=%s\n' "$label" "$file"
  if have_file "$file"; then
    "$TAIL" -n 5 "$file" 2>/dev/null || warn "could not read $file"
  else
    result "missing"
  fi
}

printf 'CHECK: identity\n'
printf 'RESULT: host=%s user=%s repo=%s\n' "$(hostname -s)" "$(id -un)" "$REPO"

section "service state"
show_unit_state "unbound"
show_unit_state "AdGuardHome"

section "timer active state"
show_timer_active "dns-health.timer"
show_timer_active "backup-health.timer"
show_timer_active "infra-auto-sync.timer"

section "timer schedule"
run_systemctl list-timers --all --no-pager 2>/dev/null \
  | grep -E 'dns-health|backup-health|infra-auto-sync' || warn "expected timers not listed"

section "safe log tails"
tail_safe_log "dns-health" "$LOG_DIR/dns-health.log"
tail_safe_log "dns-health-fail" "$LOG_DIR/dns-health-fail.log"
tail_safe_log "backup-health" "$LOG_DIR/backup-health.log"

section "disk usage"
for path in "$REPO" "$STATE_DIR" "$LOG_DIR"; do
  if [ -e "$path" ]; then
    "$DF" -h "$path" 2>/dev/null | tail -n 1 | awk -v path="$path" '{print "RESULT: path=" path " size="$2" used="$3" avail="$4" pct="$5}'
  else
    warn "$path is missing"
  fi
done

printf '\nSTATUS: %s\n' "$status"
