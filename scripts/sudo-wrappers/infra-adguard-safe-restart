#!/usr/bin/env bash
# Purpose: Higher-risk guarded AdGuard Home restart without exposing config.
# Author:  codex-agent | Date: 2026-05-05
set -euo pipefail
IFS=$'\n\t'

readonly ADGUARD_CONFIG="/home/pi/AdGuardHome/AdGuardHome.yaml"
readonly BACKUP_WRAPPER="/usr/local/sbin/infra-backup-dns-export"
readonly SYSTEMCTL="/usr/bin/systemctl"
readonly DIG="/usr/bin/dig"
readonly SS="/usr/bin/ss"
readonly TIMEOUT="/usr/bin/timeout"

require_dig() {
  local label="$1"
  local name="$2"
  local out
  printf 'CHECK: dig %s via 192.168.1.55:53\n' "$label"
  out="$("$TIMEOUT" 10s "$DIG" @192.168.1.55 "$name" A +short)"
  if [ -z "$out" ]; then
    printf 'STATUS: FAIL\n'
    printf 'RESULT: FAIL empty DNS answer for %s\n' "$label"
    exit 1
  fi
  printf '%s\n' "$out" | sed 's/^/RESULT: /'
}

printf 'CHECK: risk\n'
printf 'RESULT: WARN higher-risk wrapper; requires separate live approval before use\n'

printf 'CHECK: AdGuard config presence\n'
if [ ! -f "$ADGUARD_CONFIG" ]; then
  printf 'STATUS: FAIL\n'
  printf 'RESULT: FAIL missing %s\n' "$ADGUARD_CONFIG"
  exit 1
fi
printf 'RESULT: PASS config file exists; content not printed\n'

printf 'CHECK: optional sanitized DNS export\n'
if [ -x "$BACKUP_WRAPPER" ]; then
  "$TIMEOUT" 60s "$BACKUP_WRAPPER"
  printf 'RESULT: PASS backup export wrapper completed\n'
else
  printf 'RESULT: WARN %s missing; skipping export\n' "$BACKUP_WRAPPER"
fi

printf 'CHECK: restart AdGuardHome\n'
"$TIMEOUT" 30s "$SYSTEMCTL" restart AdGuardHome
printf 'RESULT: PASS AdGuardHome restart requested\n'

printf 'CHECK: AdGuardHome active\n'
"$TIMEOUT" 10s "$SYSTEMCTL" is-active --quiet AdGuardHome
printf 'RESULT: PASS AdGuardHome active\n'

printf 'CHECK: listening ports\n'
"$TIMEOUT" 10s "$SS" -lntup 2>/dev/null | grep -E ':(53|443|853|3000)\b' || true

require_dig "pi.home.lan" "pi.home.lan"
require_dig "cloudflare.com" "cloudflare.com"

printf 'STATUS: PASS\n'
